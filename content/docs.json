{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "gaal",
  "colors": {
    "primary": "#DEFF9A",
    "light": "#DEFF9A",
    "dark": "#DEFF9A"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#000000"
    }
  },
  "fonts": {
    "family": "Urbanist",
    "weight": 500
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "install",
              "quickstart",
              "how-gaal-works"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/gaal-yaml",
              "concepts/repositories",
              "concepts/skills",
              "concepts/mcp-servers",
              "concepts/agents-and-renderers",
              "concepts/scopes",
              "concepts/telemetry"
            ]
          },
          {
            "group": "Configure",
            "pages": [
              "configure/repositories",
              "configure/skills",
              "configure/mcp-servers",
              "configure/custom-agents",
              "configure/environment-and-secrets"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "workflows/first-time-setup",
              "workflows/sync-vs-service",
              "workflows/dry-run",
              "workflows/pruning",
              "workflows/pinning",
              "workflows/sandbox-mode",
              "workflows/sharing-across-machines"
            ]
          },
          {
            "group": "Agent integrations",
            "pages": [
              "agents/overview",
              "agents/claude-code",
              "agents/cursor",
              "agents/codex",
              "agents/github-copilot",
              "agents/windsurf",
              "agents/continue",
              "agents/gemini-cli",
              "agents/goose",
              "agents/cline",
              "agents/roo",
              "agents/augment",
              "agents/opencode",
              "agents/openhands",
              "agents/trae",
              "agents/kilo",
              "agents/kiro-cli",
              "agents/amp",
              "agents/zencoder",
              "agents/antigravity",
              "agents/warp",
              "agents/generic"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/doctor",
              "troubleshooting/common-errors",
              "troubleshooting/faq"
            ]
          }
        ]
      },
      {
        "tab": "CLI reference",
        "groups": [
          {
            "group": "CLI reference",
            "pages": [
              "cli/overview",
              "cli/sync",
              "cli/status",
              "cli/agents",
              "cli/info",
              "cli/init",
              "cli/audit",
              "cli/doctor",
              "cli/migrate",
              "cli/schema",
              "cli/version",
              "cli/completion"
            ]
          }
        ]
      },
      {
        "tab": "Schema reference",
        "groups": [
          {
            "group": "gaal.yaml schema",
            "pages": [
              "schema/overview",
              "schema/schema-version",
              "schema/repositories",
              "schema/skills",
              "schema/mcps",
              "schema/telemetry"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://getgaal.com",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/getgaal/gaal",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://getgaal.com"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/getgaal/gaal"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/getgaal",
      "x": "https://x.com/getgaal"
    }
  }
}
